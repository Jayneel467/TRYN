# Resend — https://resend.com
# REQUIRED for contact & pitch-deck forms. Without this key, submissions return
# queued: false and the site shows "Delivery not configured yet".
RESEND_API_KEY=

# Contact form routing (optional — these defaults are used if unset)
CONTACT_TO_EMAIL=support@tryn.studio
CONTACT_FROM_EMAIL=TRYN Studios <hello@tryn.studio>

# Newsletter only — NOT required for the contact form
RESEND_AUDIENCE_ID=

# Optional public URLs
NEXT_PUBLIC_SITE_URL=https://trynstudios.com
NEXT_PUBLIC_WHATSAPP_URL=
NEXT_PUBLIC_CAL_EMBED_URL=
