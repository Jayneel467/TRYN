# ── Free email (recommended) — Web3Forms ───────────────────────────────────
# 1. Go to https://web3forms.com and click "Create Access Key"
# 2. Enter support@tryn.studio as the notification email
# 3. Copy the access key and paste it below (and in Vercel → Settings → Environment Variables)
# Free tier: unlimited submissions. Attachments up to 10MB (pitch decks over 10MB use SMTP/Resend fallback).
WEB3FORMS_ACCESS_KEY=

# ── Optional: SMTP (Zoho, Gmail app password, domain mailbox) ───────────────
# Use when you need attachments over 10MB or prefer your own mail server.
# SMTP_HOST=smtp.zoho.com
# SMTP_PORT=587
# SMTP_USER=support@tryn.studio
# SMTP_PASS=

# ── Optional: Resend fallback (paid) ──────────────────────────────────────────
# Only needed if you already use Resend. Web3Forms is tried first.
# RESEND_API_KEY=

# Contact form routing (optional — used by SMTP/Resend; Web3Forms uses dashboard email)
CONTACT_TO_EMAIL=support@tryn.studio
CONTACT_FROM_EMAIL=TRYN Studios <hello@tryn.studio>

# Optional public URLs
NEXT_PUBLIC_SITE_URL=https://tryn.studio
NEXT_PUBLIC_WHATSAPP_URL=
NEXT_PUBLIC_CAL_EMBED_URL=
